# =============================================================================
# Kutubxona.uz — Multi-Tenant Digital Library Platform
# Environment Configuration
#
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in ALL required values (marked with REQUIRED)
#   3. Never commit the actual .env file to version control
# =============================================================================

# =============================================================================
# Application
# =============================================================================
APP_NAME="Kutubxona.uz"
APP_ENV=production                          # local | staging | production
APP_KEY=                                    # REQUIRED: php artisan key:generate
APP_DEBUG=false                             # NEVER true in production
APP_URL=https://kutubxona.uz
APP_BASE_DOMAIN=kutubxona.uz               # Base domain for subdomain routing
APP_VERSION=1.0.0
APP_TIMEZONE=Asia/Tashkent
APP_LOCALE=uz

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                             # debug | info | warning | error | critical

# =============================================================================
# Database — Primary (Write)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql                               # Docker service name or IP
DB_PORT=3306
DB_DATABASE=kutubxona                       # REQUIRED
DB_USERNAME=kutubxona                       # REQUIRED
DB_PASSWORD=                                # REQUIRED — use strong password in production

# =============================================================================
# Database — Read Replica (optional)
# =============================================================================
DB_READ_HOST=                               # Leave empty to use primary for reads
DB_READ_PORT=3306
DB_READ_DATABASE=kutubxona
DB_READ_USERNAME=kutubxona_readonly
DB_READ_PASSWORD=                           # REQUIRED if using replica

# =============================================================================
# Database — Dedicated Tenant Connection (premium tenants)
# =============================================================================
TENANT_DEDICATED_DB_HOST=
TENANT_DEDICATED_DB_PORT=3306
TENANT_DEDICATED_DB_USERNAME=
TENANT_DEDICATED_DB_PASSWORD=

# =============================================================================
# MySQL Connection Pooling
# =============================================================================
DB_POOL_MIN=5
DB_POOL_MAX=100
DB_STRICT=true
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# =============================================================================
# Cache
# =============================================================================
CACHE_DRIVER=redis
CACHE_PREFIX=kutubxona_

# =============================================================================
# Session
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# =============================================================================
# Queue
# =============================================================================
QUEUE_CONNECTION=redis
# Queue names (comma-separated priority order):
# critical,emails,file-processing,analytics,notifications,default

# =============================================================================
# Redis
# =============================================================================
REDIS_CLIENT=predis
REDIS_HOST=redis                            # Docker service name or IP
REDIS_PASSWORD=                             # REQUIRED — set strong password
REDIS_PORT=6379
REDIS_MAX_MEMORY=512mb

# Redis DB indexes (separate DBs for isolation)
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_THROTTLE_DB=4
REDIS_HORIZON_DB=5

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET=                                 # REQUIRED: php artisan jwt:secret (HS256 fallback)
JWT_ALGO=RS256                              # RS256 recommended for production
JWT_TTL=60                                  # Access token TTL in minutes
JWT_REFRESH_TTL=20160                       # Refresh token TTL in minutes (14 days)
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=30              # Seconds before old token is rejected after refresh

# For RS256 — provide base64-encoded key content
JWT_PUBLIC_KEY=                             # REQUIRED for RS256: base64 encoded public key
JWT_PRIVATE_KEY=                            # REQUIRED for RS256: base64 encoded private key
JWT_PASSPHRASE=                             # Optional passphrase for private key

# Key generation:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#   Then base64 encode each key file

# =============================================================================
# Multi-Tenancy
# =============================================================================
TENANT_CACHE_TTL=600                        # Seconds to cache tenant domain lookups
TENANT_DATABASE_MODE=shared                 # shared | dedicated
TENANT_TRIAL_DAYS=14
DEFAULT_PLAN_SLUG=free
TENANT_SAMPLE_DATA=false                    # Create sample data for new tenants

# =============================================================================
# AWS S3 / MinIO
# =============================================================================
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=                          # REQUIRED
AWS_SECRET_ACCESS_KEY=                      # REQUIRED
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=                                 # REQUIRED — your S3 bucket name
AWS_URL=                                    # Optional CDN/CloudFront URL for public assets
AWS_ENDPOINT=                               # MinIO endpoint for local dev (e.g., http://minio:9000)
AWS_USE_PATH_STYLE_ENDPOINT=false           # Set to true for MinIO

# =============================================================================
# CDN (CloudFront or similar)
# =============================================================================
CDN_ENABLED=false
CDN_URL=                                    # e.g., https://d1234567890.cloudfront.net

# =============================================================================
# File Storage Limits
# =============================================================================
MAX_BOOK_FILE_MB=100
MAX_AUDIO_FILE_MB=300
MAX_IMAGE_MB=5
MAX_AVATAR_MB=2

# =============================================================================
# Signed URL TTLs (seconds)
# =============================================================================
SIGNED_URL_DOWNLOAD_TTL=3600               # 1 hour for downloads
SIGNED_URL_STREAM_TTL=900                  # 15 minutes for streaming
SIGNED_URL_AVATAR_TTL=86400                # 24 hours for avatars

# =============================================================================
# Email
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=                                  # REQUIRED
MAIL_PORT=587
MAIL_USERNAME=                              # REQUIRED
MAIL_PASSWORD=                              # REQUIRED
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@kutubxona.uz
MAIL_FROM_NAME="Kutubxona.uz"

# Production recommendations: SES, Postmark, or SendGrid
# MAIL_MAILER=ses
# AWS_SES_KEY=
# AWS_SES_SECRET=
# AWS_SES_REGION=us-east-1

# =============================================================================
# Virus Scanning (ClamAV)
# =============================================================================
VIRUS_SCAN_ENABLED=false                    # Enable in production if ClamAV is installed
VIRUS_SCAN_COMMAND="clamscan --no-summary"

# =============================================================================
# Rate Limiting
# =============================================================================
# Requests per minute (default throttle:api)
RATE_LIMIT_API=120
RATE_LIMIT_AUTH=10
RATE_LIMIT_DOWNLOADS=20
RATE_LIMIT_SEARCH=60
RATE_LIMIT_UPLOAD=10

# =============================================================================
# Security
# =============================================================================
BCRYPT_ROUNDS=12

# CORS — allowed origins (comma separated or *)
CORS_ALLOWED_ORIGINS=https://kutubxona.uz,https://app.kutubxona.uz

# =============================================================================
# Horizon (Queue Dashboard)
# =============================================================================
HORIZON_ENABLED=true
HORIZON_PREFIX=kutubxona_horizon:
# Restrict dashboard access — comma-separated email list for production
HORIZON_BASIC_AUTH_USERNAME=horizon
HORIZON_BASIC_AUTH_PASSWORD=               # REQUIRED — set strong password

# =============================================================================
# Telescope (Debugging — DISABLE in production)
# =============================================================================
TELESCOPE_ENABLED=false

# =============================================================================
# Scout (Full-text Search)
# =============================================================================
SCOUT_DRIVER=mysql                          # mysql | algolia | meilisearch | elasticsearch
SCOUT_QUEUE=true
SCOUT_PREFIX=kutubxona_

# Algolia (if SCOUT_DRIVER=algolia)
ALGOLIA_APP_ID=
ALGOLIA_SECRET=

# Meilisearch (if SCOUT_DRIVER=meilisearch)
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# Elasticsearch (if SCOUT_DRIVER=elasticsearch)
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# =============================================================================
# Push Notifications
# =============================================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

BROADCAST_DRIVER=log                        # log | pusher | redis | null

# =============================================================================
# External Services
# =============================================================================
# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Sentry (error tracking)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# =============================================================================
# Docker
# =============================================================================
# MySQL root password (Docker only)
MYSQL_ROOT_PASSWORD=                        # REQUIRED for docker-compose

# Nginx ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Optional external ports for direct access (dev only)
MYSQL_EXTERNAL_PORT=3306
REDIS_EXTERNAL_PORT=6379

# MinIO (local development only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_DOMAIN=minio

# =============================================================================
# Scheduler / Maintenance
# =============================================================================
# Cleanup temp files older than (hours)
TEMP_FILE_MAX_AGE_HOURS=24

# Analytics partition maintenance (auto-add monthly partitions)
ANALYTICS_AUTO_PARTITION=true
