{
    "name": "kutubxona/backend",
    "description": "Kutubxona.uz — Multi-tenant Digital Library SaaS Platform",
    "keywords": ["laravel", "digital-library", "saas", "multi-tenant"],
    "license": "proprietary",
    "type": "project",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-redis": "*",
        "ext-pdo": "*",
        "aws/aws-sdk-php": "^3.300",
        "fruitcake/php-cors": "^1.3",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.24",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.9",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.25",
        "predis/predis": "^2.2",
        "sentry/sentry-laravel": "^4.7",
        "spatie/laravel-fractal": "^6.1",
        "spatie/laravel-medialibrary": "^11.7",
        "spatie/laravel-permission": "^6.7",
        "spatie/laravel-query-builder": "^5.8",
        "spatie/laravel-sluggable": "^3.6",
        "tymon/jwt-auth": "^2.1",
        "symfony/http-client": "^7.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.15",
        "laravel/sail": "^1.29",
        "laravel/telescope": "^5.1",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.4",
        "spatie/laravel-ignition": "^2.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan jwt:secret --ansi"
        ],
        "test": [
            "@php artisan test"
        ],
        "test-coverage": [
            "XDEBUG_MODE=coverage ./vendor/bin/pest --coverage --min=80"
        ],
        "format": [
            "./vendor/bin/pint"
        ],
        "analyse": [
            "./vendor/bin/phpstan analyse --memory-limit=2G"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-pcntl": "8.3.0",
            "ext-posix": "8.3.0",
            "ext-redis": "6.0.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
