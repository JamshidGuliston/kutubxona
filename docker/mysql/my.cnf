[mysqld]
# =============================================================================
# MySQL 8.0 — Kutubxona.uz Production Configuration
# =============================================================================

# Character set
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci
init-connect          = 'SET NAMES utf8mb4'

# InnoDB — Buffer Pool (set to ~70% of available RAM)
innodb_buffer_pool_size         = 512M
innodb_buffer_pool_instances    = 4
innodb_log_file_size            = 128M
innodb_log_buffer_size          = 64M
innodb_flush_log_at_trx_commit  = 2      # 1 = safest, 2 = performance
innodb_flush_method             = O_DIRECT
innodb_file_per_table           = 1
innodb_stats_on_metadata        = 0
innodb_read_io_threads          = 8
innodb_write_io_threads         = 8

# Connections
max_connections                 = 200
max_allowed_packet              = 256M
thread_cache_size               = 50
open_files_limit                = 65535
table_open_cache                = 4000
table_definition_cache          = 2000

# Query Cache (disabled in MySQL 8.0 by default — good)
query_cache_type                = 0
query_cache_size                = 0

# Temporary tables
tmp_table_size                  = 128M
max_heap_table_size             = 128M

# Slow Query Log
slow_query_log                  = 1
slow_query_log_file             = /var/lib/mysql/slow.log
long_query_time                 = 2
log_queries_not_using_indexes   = 0
min_examined_row_limit          = 100

# Binary Logging (for replication)
log_bin                         = mysql-bin
binlog_format                   = ROW
binlog_expire_logs_seconds      = 604800  # 7 days
max_binlog_size                 = 256M
sync_binlog                     = 1

# Replication
server-id                       = 1
gtid_mode                       = ON
enforce_gtid_consistency        = ON

# Performance Schema
performance_schema              = ON
performance_schema_max_table_instances = 400

# Full-Text Search (for Scout driver)
ft_min_word_len                 = 2
innodb_ft_min_token_size        = 2

# Partitioning (for analytics_events)
# Already enabled by default in MySQL 8.0

# SQL Mode
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[mysql]
default-character-set = utf8mb4

[client]
default-character-set = utf8mb4
